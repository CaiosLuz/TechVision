<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D3D3D3">

    <include
        android:id="@+id/includeTopBar"
        layout="@layout/top_bar_padrao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="30dp"
        app:layout_constraintBottom_toTopOf="@id/includeBottomMenu"
        app:layout_constraintTop_toBottomOf="@id/includeTopBar">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@android:drawable/checkbox_on_background"
            android:background="@drawable/circle_bg"
            android:backgroundTint="#2ECC71"
            android:padding="20dp"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Seu pedido foi realizado com sucesso!"
            android:textAlignment="center"
            android:textColor="#333"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Agradecemos pela compra! Te manteremos informado sobre o status"
            android:textAlignment="center"
            android:textColor="#666"
            android:textSize="16sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVoltarHome"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/table_border"
            android:drawableStart="@android:drawable/ic_menu_sort_by_size"
            android:paddingStart="20dp"
            android:text="VOLTAR PARA A HOME"
            android:textColor="#455A64"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnVisualizarPedido"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:background="@drawable/btn_primary_rounded"
            android:backgroundTint="#455A64"
            android:text="VISUALIZAR PEDIDO →"
            android:textColor="#FFF"
            android:textStyle="bold" />

    </LinearLayout>

    <include
        android:id="@+id/includeBottomMenu"
        layout="@layout/bottom_menu_padrao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
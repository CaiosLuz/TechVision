<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_gray">

        <LinearLayout
            android:id="@+id/topBarCarrinho"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="@color/primary_dark"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <EditText
                android:id="@+id/etPesquisarCarrinho"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_weight="1"
                android:background="@drawable/circle_bg"
                android:backgroundTint="@color/white"
                android:hint="Pesquisar"
                android:paddingStart="15dp"
                android:drawableEnd="@android:drawable/ic_menu_search"
                android:paddingEnd="15dp"
                android:focusable="false" />

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/circle_bg"
                android:backgroundTint="#D1D1D1"
                android:gravity="center"
                android:text="US"
                android:textColor="@color/primary_dark"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtTituloCarrinho"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meu Carrinho"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_margin="16dp"
            android:textColor="@color/primary_dark"
            app:layout_constraintTop_toBottomOf="@id/topBarCarrinho"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCarrinho"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/txtTituloCarrinho"
            app:layout_constraintBottom_toTopOf="@id/layoutCheckout"/>

        <LinearLayout
            android:id="@+id/layoutCheckout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/white"
            android:elevation="8dp"
            app:layout_constraintBottom_toTopOf="@id/bottomMenu">

            <TextView
                android:id="@+id/txtTotalCarrinho"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total: R$ 0,00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:layout_marginBottom="8dp"/>

            <Button
                android:id="@+id/btnFinalizarCompra"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="FINALIZAR PEDIDO"
                android:backgroundTint="@color/primary_dark"
                android:textColor="@color/white"
                app:cornerRadius="8dp"/>
        </LinearLayout>

        <include
            android:id="@+id/bottomMenu"
            layout="@layout/bottom_menu_padrao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigation_view"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/white"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
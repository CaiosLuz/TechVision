<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_resumo"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/topBarResumo"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#3E4A52"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TechVision"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="US"
            android:textColor="#3E4A52"
            android:textStyle="bold"
            android:background="@drawable/circle_bg"
            android:backgroundTint="#D1D1D1"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBarResumo"
        app:layout_constraintBottom_toTopOf="@id/btnConcluirCompra">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumo da compra"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:textColor="#333"
                android:layout_marginBottom="16dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PRODUTO"
                        android:textSize="12sp"
                        android:background="#F0F0F0"
                        android:padding="8dp"
                        android:textColor="#666"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingVertical="12dp">

                        <ImageView
                            android:id="@+id/imgProdutoResumo"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:scaleType="fitCenter"
                            android:background="#FFF"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/txtNomeProdutoResumo"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Carregando nome..."
                            android:layout_marginTop="12dp"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#000"
                            android:gravity="center"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtDetalhesSelecao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo: -\nEspessura: -"
                        android:textColor="#333"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="20dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="25dp">

                        <TextView
                            android:id="@+id/lblQtd"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="QUANTIDADE"
                            android:textSize="10sp"
                            android:textStyle="bold"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/lblQtd"
                            android:layout_marginTop="5dp"
                            android:background="@drawable/table_border"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="— 01 +"
                                android:textColor="#000"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:gravity="end"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VALOR" android:textSize="10sp" android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/txtValorFinal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R$ 0,00"
                                android:textColor="#000"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prescrição Médica Extraída (IA):"
                        android:textStyle="bold"
                        android:textColor="#000"
                        android:layout_marginBottom="12dp"/>

                    <TableLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:stretchColumns="*"
                        android:layout_marginBottom="15dp">

                        <TableRow android:background="#F0F0F0">
                            <TextView android:text="" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:text="Esférico" android:textStyle="bold" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:text="Cilíndrico" android:textStyle="bold" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:text="Eixo" android:textStyle="bold" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                        </TableRow>

                        <TableRow>
                            <TextView android:text="OD" android:textStyle="bold" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:id="@+id/tvEsfOD" android:text="0.00" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:id="@+id/tvCilOD" android:text="0.00" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:id="@+id/tvEixoOD" android:text="0" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                        </TableRow>

                        <TableRow>
                            <TextView android:text="OE" android:textStyle="bold" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:id="@+id/tvEsfOE" android:text="0.00" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:id="@+id/tvCilOE" android:text="0.00" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                            <TextView android:id="@+id/tvEixoOE" android:text="0" android:gravity="center" android:padding="8dp" android:background="@drawable/table_border"/>
                        </TableRow>
                    </TableLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="* Verifique se os graus acima conferem com sua receita física."
                        android:textSize="11sp"
                        android:textColor="#E74C3C"
                        android:gravity="center"
                        android:layout_marginTop="5dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnConcluirCompra"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/btn_primary_rounded"
        android:backgroundTint="#2ECC71"
        android:text="CONCLUIR COMPRA"
        android:textColor="#FFF"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/includeBottomMenu" />

    <include
        android:id="@+id/includeBottomMenu"
        layout="@layout/bottom_menu_padrao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
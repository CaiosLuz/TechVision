        <shape>
            <solid android:color="#2F383E"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape>
            <solid android:color="#4A565E"/>
            <corners android:radius="30dp"/>
        </shape>
    </item>

</selector>